{
  "name": "ollama-bridge-proxy",
  "version": "1.0.0",
  "description": "Companion proxy for Ollama Bridge Foundry VTT module — eliminates CORS by routing API calls through a local Node server.",
  "main": "ollama-proxy.js",
  "scripts": {
    "start": "node ollama-proxy.js",
    "pm2:start": "pm2 start ollama-proxy.js --name ollama-bridge-proxy",
    "pm2:stop": "pm2 stop ollama-bridge-proxy",
    "pm2:restart": "pm2 restart ollama-bridge-proxy"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT"
}